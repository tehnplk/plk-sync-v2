# HOSxP database connection
# Use mysql, mariadb, postgres, or postgresql.
HOSXP_DB_TYPE=mysql
HOSXP_DB_HOST=host.docker.internal
HOSXP_DB_PORT=3306
HOSXP_DB_NAME=your_database_name
HOSXP_DB_USER=your_db_user
HOSXP_DB_PASSWORD=your_db_password

# Optional: override SQL file. If omitted, Python picks by HOSXP_DB_TYPE.
# HOSXP_SQL_FILE=mysql_visit_type_count.sql

# VISIT TYPE API
VISIT_TYPE_DAILY_API_URL=https://dashboard.plkhealth.go.th/telemedicine/api/visit-type-daily
VISIT_TYPE_DAILY_TIMEOUT=60
VISIT_TYPE_DAILY_DRY_RUN=false
VISIT_TYPE_DAILY_PRETTY=true
