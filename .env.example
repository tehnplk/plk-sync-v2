# HOSxP database connection
# Use mysql, mariadb, postgres, or postgresql.
DB_TYPE=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Optional: override SQL file. If omitted, Python picks by DB_TYPE.
# SQL_FILE=mysql_visit_type_count.sql

# VISIT TYPE API
VISIT_TYPE_DAILY_API_URL=https://dashboard.plkhealth.go.th/telemedicine/api/visit-type-daily
SYNC_TIMEZONE=Asia/Bangkok
VISIT_TYPE_DAILY_TIMEOUT=60
VISIT_TYPE_DAILY_DRY_RUN=false
VISIT_TYPE_DAILY_PRETTY=true
